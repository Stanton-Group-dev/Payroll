# ──────────────────────────────────────────────────────────────────────────────
# Env var REFERENCE — placeholder names only, never real values.
# Secrets live in Bitwarden Secrets Manager, not in files. For local dev:
#   1. Get BWS_ACCESS_TOKEN from an Owner (set it once in your shell env).
#   2. Run the app with:  bws run -- npm run dev
# That injects the values below from Bitwarden at runtime — no .env.local needed.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase — the publishable key is the browser-safe key (sb_publishable_...).
# This app reads NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY first, then falls back to
# the legacy anon key. Use the publishable key for new setups.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable-key>   # sb_publishable_... (safe in browser)

# Legacy anon key — only if a publishable key is not available (being phased out).
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Natural-language command bar (SERVER ONLY — no NEXT_PUBLIC_ prefix).
# Powers /api/payroll/agent. Without it the command bar returns a clear 503 and
# the rest of the app is unaffected. Get an Anthropic API key from the console.
ANTHROPIC_API_KEY=<anthropic-api-key>           # sk-ant-...
# Optional model override (defaults to claude-sonnet-4-6).
# PAYROLL_AGENT_MODEL=claude-sonnet-4-6

# Workyard time-tracking integration (SERVER ONLY — no NEXT_PUBLIC_ prefix).
# Required for time card ingestion / the import page; the API throws without them.
WORKYARD_API_KEY=<workyard-api-key>
WORKYARD_ORG_ID=<workyard-org-id>

# Dev/test only: when set to 1/true, the API-pull import path returns deterministic
# dummy time cards (matching the seeded employees + property S-codes) instead of
# calling Workyard — so the import flow can be tested without real creds. Leave
# unset/0 in any real environment.
# WORKYARD_MOCK=1
