# ──────────────────────────────────────────────────────────────────────────────
# Env var REFERENCE — placeholder names only, never real values.
# Secrets live in Infisical (self-hosted on Railway), not in files. For local dev:
#   1. Authenticate once:  infisical login  (against the Stanton self-hosted instance).
#   2. Run the app with:  infisical run -- npm run dev
# That injects the values below from Infisical at runtime — no .env.local needed.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase — the publishable key is the browser-safe key (sb_publishable_...).
# This app reads NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY first, then falls back to
# the legacy anon key. Use the publishable key for new setups.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable-key>   # sb_publishable_... (safe in browser)

# Legacy anon key — only if a publishable key is not available (being phased out).
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Natural-language command bar (SERVER ONLY — no NEXT_PUBLIC_ prefix).
# Powers /api/payroll/agent. Without it the command bar returns a clear 503 and
# the rest of the app is unaffected. Get an Anthropic API key from the console.
ANTHROPIC_API_KEY=<anthropic-api-key>           # sk-ant-...
# Optional model override (defaults to claude-sonnet-4-6).
# PAYROLL_AGENT_MODEL=claude-sonnet-4-6

# Workyard time-tracking integration (SERVER ONLY — no NEXT_PUBLIC_ prefix).
# Required for time card ingestion / the import page; the API throws without them.
WORKYARD_API_KEY=<workyard-api-key>
WORKYARD_ORG_ID=<workyard-org-id>

# Dev/test only: when set to 1/true, the API-pull import path returns deterministic
# dummy time cards (matching the seeded employees + property S-codes) instead of
# calling Workyard — so the import flow can be tested without real creds. Leave
# unset/0 in any real environment.
# WORKYARD_MOCK=1

# Monitask remote-worker activity integration (SERVER ONLY — no NEXT_PUBLIC_ prefix).
# Monitask uses OAuth2 (IdentityServer): request API access from Monitask, register
# an app to get a client id/secret, complete the OAuth flow once to obtain a refresh
# token, then set the three below. Access tokens are refreshed automatically.
# Without these the /api/monitask/* routes return a graceful 503; the app is unaffected.
MONITASK_CLIENT_ID=<monitask-client-id>
MONITASK_CLIENT_SECRET=<monitask-client-secret>
MONITASK_REFRESH_TOKEN=<monitask-refresh-token>
# Optional: override the activity/report data endpoint + base once Monitask grants
# the real paths via their developer portal (defaults are best-guess placeholders).
# MONITASK_API_BASE=https://app.monitask.com/api
# MONITASK_ACTIVITY_PATH=/v1/reports/activity
# Dev/test only: deterministic dummy activity instead of calling Monitask.
# MONITASK_MOCK=1

# Supabase service-role key (SERVER ONLY — NEVER expose to the browser). Powers the
# admin user-management route (/api/admin/users): invite, password reset, resend,
# delete. Without it those actions return a clear error; the rest of the app works.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # sb_secret_... / service_role JWT

# Twilio SMS (SERVER ONLY — no NEXT_PUBLIC_ prefix). Powers the unallocated-hours
# notifications (/api/payroll/holds): when an employee is pulled from pay for
# unallocated hours, they're texted to come in with a written reason. WITHOUT these
# the feature still works but runs as a DRY RUN — messages are composed and logged
# to payroll_notifications, but nothing is actually sent. Set all three to go live.
# TWILIO_ACCOUNT_SID=<twilio-account-sid>        # AC...
# TWILIO_AUTH_TOKEN=<twilio-auth-token>
# TWILIO_FROM_NUMBER=<e164-sender>               # e.g. +15551234567
# Alternatively use a Messaging Service instead of a single From number:
# TWILIO_MESSAGING_SERVICE_SID=<messaging-service-sid>   # MG...
# Dev/test only: force dry-run even when the creds above are set.
# TWILIO_MOCK=1
